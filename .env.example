# ════════════════════════════════════════
# DATABASE – MongoDB Atlas hoặc local
# ════════════════════════════════════════
MONGODB_URI=mongodb+srv://buiminh19102004_db_user:Ubtech123%40@cluster0.h2mkwii.mongodb.net/ubtechweb?retryWrites=true&w=majority

# ════════════════════════════════════════
# SERVER
# ════════════════════════════════════════
PORT=5000
NODE_ENV=production

# ════════════════════════════════════════
# JWT – đổi thành chuỗi random dài ≥ 32 ký tự
# ════════════════════════════════════════
JWT_ACCESS_SECRET=change_this_to_a_random_secret_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_random_secret_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ════════════════════════════════════════
# FRONTEND URL (CORS) – có thể nhiều URL cách nhau dấu phẩy
# ════════════════════════════════════════
CLIENT_URL=https://your-frontend.vercel.app

# ════════════════════════════════════════
# EMAIL – Gmail App Password
# Hướng dẫn: https://myaccount.google.com/apppasswords
# ════════════════════════════════════════
MAIL_FROM=yourshop@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx
ADMIN_EMAIL=admin@yourshop.com
SHOP_NAME=UBTECH Việt Nam
ZALO_PHONE=0900000000

# ════════════════════════════════════════
# VNPAY – https://vnpay.vn/dang-ky-merchant
# ════════════════════════════════════════
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET
VNPAY_URL=https://pay.vnpay.vn/vpcpay.html
VNPAY_RETURN_URL=https://your-backend.vercel.app/api/payments/vnpay/callback

# ════════════════════════════════════════
# MOMO – https://business.momo.vn
# ════════════════════════════════════════
MOMO_PARTNER_CODE=YOUR_PARTNER_CODE
MOMO_ACCESS_KEY=YOUR_ACCESS_KEY
MOMO_SECRET_KEY=YOUR_SECRET_KEY
MOMO_ENDPOINT=https://payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://your-frontend.vercel.app/payment/result
MOMO_IPN_URL=https://your-backend.vercel.app/api/payments/momo/callback

# ════════════════════════════════════════
# ZALOPAY – https://zalopay.vn/developer
# ════════════════════════════════════════
ZALOPAY_APP_ID=YOUR_APP_ID
ZALOPAY_KEY1=YOUR_KEY1
ZALOPAY_KEY2=YOUR_KEY2
ZALOPAY_ENDPOINT=https://openapi.zalopay.vn/v2/create
ZALOPAY_CALLBACK_URL=https://your-backend.vercel.app/api/payments/zalopay/callback
ZALOPAY_REDIRECT_URL=https://your-frontend.vercel.app/payment/result

# ════════════════════════════════════════
# CHUYỂN KHOẢN NGÂN HÀNG / VIETQR
# ════════════════════════════════════════
BANK_NAME=HDBank
BANK_ACCOUNT=YOUR_ACCOUNT_NUMBER
BANK_OWNER=YOUR_FULL_NAME
BANK_BRANCH=Chi_Nhanh_Dong_Nai
BANK_BIN=970437

# ════════════════════════════════════════
# VIETQR AUTO-DETECT (Payment Checker Worker)
# Chỉ hoạt động ở môi trường long-running (VPS, Railway, Render)
# KHÔNG chạy trên Vercel serverless
# Provider: casso | sepay
# ════════════════════════════════════════
BANK_PROVIDER=casso
CASSO_API_KEY=
# SEPAY_API_KEY=
# SEPAY_ACCOUNT_ID=
TRANSFER_PREFIX=TT
PAYMENT_CHECK_INTERVAL_MS=5000
PAYMENT_MAX_BACKOFF_MS=60000
PAYMENT_BACKOFF_MULT=2
PAYMENT_MAX_ERRORS=3
